// ─────────────────────────────────────────────────────────────────────────────
// Enterprise — Prisma Schema
// Multi-tenant marketing connections with encrypted token storage.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Users (mirrors NextAuth sessions for FK references) ─────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connections MarketingConnection[]
  trackEvents TrackingEvent[]

  @@index([tenantId])
}

// ── Marketing Connections ───────────────────────────────────────────────────
// Each row = one platform connection for one user/tenant.
// Tokens are AES-256-GCM encrypted at rest; the `encrypted_` prefix reminds
// every developer that these columns must NEVER be read without decryption.

model MarketingConnection {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String

  platform      MarketingPlatform
  adAccountId   String?           // External platform account ID
  adAccountName String?           // Human-readable label

  // Encrypted token fields (AES-256-GCM → base64 string)
  encryptedAccessToken  String
  encryptedRefreshToken String?

  tokenExpiresAt DateTime?         // UTC expiration of the access token
  scopes         String?           // Comma-separated granted scopes

  status    ConnectionStatus @default(ACTIVE)
  metadata  String?          // JSON blob for platform-specific extras

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, adAccountId])
  @@index([tenantId])
  @@index([platform])
}

// ── Tracking Events (deduplication log) ─────────────────────────────────────

model TrackingEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String

  eventId   String   // Client-generated unique ID for deduplication
  eventName String   // e.g. "Purchase", "Lead", "PageView"
  platform  MarketingPlatform
  payload   String   // JSON-serialised event data

  sentAt    DateTime @default(now())
  status    TrackingStatus @default(SENT)
  errorMsg  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, platform])
  @@index([tenantId, eventName])
  @@index([sentAt])
}

// ── Enums ───────────────────────────────────────────────────────────────────

enum MarketingPlatform {
  META
  TIKTOK
  GOOGLE_ADS
  LINKEDIN
}

enum ConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

enum TrackingStatus {
  SENT
  FAILED
  DUPLICATE
}
