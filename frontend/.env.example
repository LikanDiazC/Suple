# =============================================================================
# SUPLE - Variables de Entorno
# =============================================================================
# Copia este archivo como .env.local y completa los valores
# cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# NextAuth.js (REQUERIDO para login)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=MBgM3PysWQc2nZMeyQXOWjdljS4WuoL2Q4tqi+lm+vU=        # Genera con: openssl rand -base64 32

# -----------------------------------------------------------------------------
# Google OAuth (REQUERIDO para login + Gmail + Contactos)
# -----------------------------------------------------------------------------
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un proyecto o selecciona uno existente
# 3. Ve a "APIs & Services" > "Credentials"
# 4. Crea un "OAuth 2.0 Client ID" tipo "Web application"
# 5. Agrega http://localhost:3000/api/auth/callback/google como Authorized redirect URI
# 6. Habilita estas APIs en "APIs & Services" > "Library":
#    - Gmail API
#    - People API (Google Contacts)
# 7. Configura el OAuth Consent Screen (puede ser "External" en testing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# SII Chile - Clave Unica (OPCIONAL - para autenticacion real con SII)
# -----------------------------------------------------------------------------
# 1. Registra tu aplicacion en https://claveunica.gob.cl/desarrolladores
# 2. Solicita acceso como integrador
# 3. Configura redirect_uri: http://localhost:3000/api/sii/callback
CLAVE_UNICA_CLIENT_ID=
CLAVE_UNICA_CLIENT_SECRET=
CLAVE_UNICA_REDIRECT_URI=http://localhost:3000/api/sii/callback

# Habilitar proxy real al SII (solo si tienes certificado digital autorizado)
SII_PROXY_ENABLED=false

# -----------------------------------------------------------------------------
# Meta (Facebook/Instagram) Ads (OPCIONAL)
# -----------------------------------------------------------------------------
# 1. Ve a https://developers.facebook.com/
# 2. Crea una app tipo "Business"
# 3. Agrega el producto "Marketing API"
# 4. Genera un token de acceso de larga duracion
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Google Ads (OPCIONAL)
# -----------------------------------------------------------------------------
# 1. Ve a https://developers.google.com/google-ads/api/docs/first-call/overview
# 2. Solicita un Developer Token
# 3. Usa el Customer ID de tu cuenta de Google Ads (sin guiones)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# -----------------------------------------------------------------------------
# TikTok Ads (OPCIONAL)
# -----------------------------------------------------------------------------
# 1. Ve a https://business-api.tiktok.com/portal/apps
# 2. Crea una app y obtiene acceso al Marketing API
TIKTOK_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# LinkedIn Ads (OPCIONAL)
# -----------------------------------------------------------------------------
# 1. Ve a https://www.linkedin.com/developers/
# 2. Crea una app con acceso a Marketing APIs
LINKEDIN_ACCESS_TOKEN=
